{
  "title": "SLO Test Dashboard (timescaledb)",
  "uid": "slo-test-timescaledb",
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "schemaVersion": 38,
  "version": 1,
  "tags": ["slo", "timescaledb"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "grafana-postgresql-datasource",
          "uid": "timescaledb"
        },
        "query": "SELECT DISTINCT service FROM metrics ORDER BY service"
      }
,      {
        "name": "interval",
        "type": "custom",
        "label": "Interval",
        "query": "1s,10s,30s,1m,5m,15m,1h,4h,12h,24h",
        "current": {
          "text": "5m",
          "value": "5m"
        },
        "options": [
          {"text": "1s", "value": "1s", "selected": false},          {"text": "10s", "value": "10s", "selected": false},          {"text": "30s", "value": "30s", "selected": false},          {"text": "1m", "value": "1m", "selected": false},          {"text": "5m", "value": "5m", "selected": true},          {"text": "15m", "value": "15m", "selected": false},          {"text": "1h", "value": "1h", "selected": false},          {"text": "4h", "value": "4h", "selected": false},          {"text": "12h", "value": "12h", "selected": false},          {"text": "24h", "value": "24h", "selected": false}        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Global Throughput",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket(\u0027$interval\u0027, t.timestamp) AS time,\n       avg(t.total) AS throughput\nFROM (\n  SELECT timestamp, sum(value) AS total\n  FROM metrics\n  WHERE metric = \u0027http_requests_total\u0027\n    AND timestamp BETWEEN $__timeFrom() AND $__timeTo()\n  GROUP BY timestamp\n) t GROUP BY 1 ORDER BY 1",
          "rawQuery": true,
          "format": "time_series",
          "refId": "A"
        }
      ]
    },    {
      "id": 2,
      "title": "Global Error Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket(\u0027$interval\u0027, t.timestamp) AS time,\n       avg(t.err) / NULLIF(avg(t.req), 0) AS error_rate\nFROM (\n  SELECT timestamp,\n         sum(CASE WHEN metric = \u0027http_errors_total\u0027 THEN value END) AS err,\n         sum(CASE WHEN metric = \u0027http_requests_total\u0027 THEN value END) AS req\n  FROM metrics\n  WHERE metric IN (\u0027http_errors_total\u0027, \u0027http_requests_total\u0027)\n    AND timestamp BETWEEN $__timeFrom() AND $__timeTo()\n  GROUP BY timestamp\n) t GROUP BY 1 ORDER BY 1",
          "rawQuery": true,
          "format": "time_series",
          "refId": "A"
        }
      ]
    },    {
      "id": 3,
      "title": "Average CPU",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT avg(value) AS avg_cpu FROM metrics WHERE metric = \u0027cpu_usage_percent\u0027\n  AND timestamp BETWEEN $__timeFrom() AND $__timeTo()",
          "rawQuery": true,
          "format": "table",
          "refId": "A"
        }
      ]
    },    {
      "id": 4,
