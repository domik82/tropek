            "uid": "timescaledb"
          },
          "rawSql": "SELECT avg(value) AS avg_memory FROM metrics WHERE metric = \u0027memory_usage_bytes\u0027\n  AND timestamp BETWEEN $__timeFrom() AND $__timeTo()",
          "rawQuery": true,
          "format": "table",
          "refId": "A"
        }
      ]
    },    {
      "id": 5,
      "title": "Throughput by Service",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket(\u0027$interval\u0027, t.timestamp) AS time,\n       avg(t.total) AS throughput\nFROM (\n  SELECT timestamp, sum(value) AS total\n  FROM metrics\n  WHERE metric = \u0027http_requests_total\u0027\n    AND service = \u0027$service\u0027\n    AND timestamp BETWEEN $__timeFrom() AND $__timeTo()\n  GROUP BY timestamp\n) t GROUP BY 1 ORDER BY 1",
          "rawQuery": true,
          "format": "time_series",
          "refId": "A"
        }
      ]
    },    {
      "id": 6,
      "title": "P99 Latency by Service",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket(\u0027$interval\u0027, timestamp) AS time,\n       percentile_cont(0.99) WITHIN GROUP (ORDER BY latency_ms) / 1000.0 AS p99_latency\nFROM request_latencies WHERE service = \u0027$service\u0027\n  AND timestamp BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY 1 ORDER BY 1",
          "rawQuery": true,
          "format": "time_series",
          "refId": "A"
        }
      ]
    },    {
      "id": 7,
      "title": "Error Rate by Service",
