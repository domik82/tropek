{
  "title": "SLO Test Dashboard (influxdb)",
  "uid": "slo-test-influxdb",
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "schemaVersion": 38,
  "version": 1,
  "tags": ["slo", "influxdb"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "influxdb",
          "uid": "influxdb"
        },
        "query": "SHOW TAG VALUES FROM \"http_requests_total\" WITH KEY = \"service\""
      }    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Global Throughput",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT mean(\"total\") AS \"throughput\" FROM (SELECT sum(\"value\") AS \"total\" FROM \"http_requests_total\" WHERE $timeFilter GROUP BY time(1s)) WHERE $timeFilter GROUP BY time(5m) fill(0)",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },    {
      "id": 2,
      "title": "Global Error Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT mean(\"err\") / mean(\"req\") AS \"error_rate\" FROM (SELECT sum(\"value\") AS \"err\" FROM \"http_errors_total\" WHERE $timeFilter GROUP BY time(1s)),\n     (SELECT sum(\"value\") AS \"req\" FROM \"http_requests_total\" WHERE $timeFilter GROUP BY time(1s))\nWHERE $timeFilter GROUP BY time(5m) fill(0)",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },    {
      "id": 3,
      "title": "Average CPU",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT mean(\"value\") AS \"avg_cpu\" FROM \"cpu_usage_percent\" WHERE $timeFilter",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },    {
      "id": 4,
      "title": "Average Memory",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT mean(\"value\") AS \"avg_memory\" FROM \"memory_usage_bytes\" WHERE $timeFilter",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },    {
      "id": 5,
      "title": "Throughput by Service",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT mean(\"total\") AS \"throughput\" FROM (SELECT sum(\"value\") AS \"total\" FROM \"http_requests_total\" WHERE \"service\" = \u0027$service\u0027 AND $timeFilter GROUP BY time(1s)) WHERE $timeFilter GROUP BY time(5m) fill(0)",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },    {
      "id": 6,
      "title": "P99 Latency by Service",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT percentile(\"value\", 99) AS \"p99_latency\" FROM \"http_request_duration_seconds\" WHERE \"service\" = \u0027$service\u0027 AND $timeFilter GROUP BY time(5m) fill(null)",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },    {
      "id": 7,
