{
  "title": "SLO Test Dashboard (prometheus)",
  "uid": "slo-test-prometheus",
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "schemaVersion": 38,
  "version": 1,
  "tags": ["slo", "prometheus"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(http_requests_total, service)"
      }    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Global Throughput",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 2,
      "title": "Global Error Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_errors_total[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 3,
      "title": "Average CPU",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "avg(cpu_usage_percent)",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 4,
      "title": "Average Memory",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "avg(memory_usage_bytes)",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 5,
      "title": "Throughput by Service",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total{service=\"$service\"}[5m]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 6,
      "title": "P99 Latency by Service",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"$service\"}[5m])))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 7,
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (service) (rate(http_errors_total[5m])) / sum by (service) (rate(http_requests_total[5m]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 8,
      "title": "CPU by Host",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "avg by (host) (cpu_usage_percent)",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 9,
      "title": "P50 Latency by Service and Host",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum by (le, service, host) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 10,
      "title": "Throughput Grouped by Service",
      "type": "barchart",
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (service) (rate(http_requests_total[5m]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 11,
      "title": "Errors Grouped by Host",
      "type": "barchart",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (host) (rate(http_errors_total[5m]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 12,
      "title": "P99 Grouped by Service",
      "type": "barchart",
      "gridPos": {
        "x": 12,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum by (le, service) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 13,
      "title": "Peak CPU",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 44,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max(cpu_usage_percent)",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 14,
      "title": "Average Latency",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 44,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_request_duration_seconds_sum[5m])) / sum(rate(http_request_duration_seconds_count[5m]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 15,
      "title": "Throughput ($__interval)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 44,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total[$__interval]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 16,
      "title": "Multi-Target",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 52,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (service) (rate(http_requests_total[5m])) or sum by (service) (rate(http_errors_total[5m]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 17,
      "title": "Subquery (COMPLEX)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 52,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max_over_time(\n  deriv(rate(http_requests_total[1m])[5m:1m]\n)[15m:])",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },    {
      "id": 18,
      "title": "Multi-level Grouping (COMPLEX)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 60,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (service, host) (\n  rate(http_requests_total[5m])\n  * on (host) group_left(region) kube_node_labels{label_region!=\"\"}\n)",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    }  ]
}
