# Test database credentials (local docker container on port 5433).
# These are defaults for the disposable test container — safe to commit.
# Start the test DB first: just test-env

# Used by api/tests/db/conftest.py directly
TEST_DATABASE_URL=postgresql+asyncpg://tropek:tropek_test@localhost:5433/tropek_test

# Used by pydantic-settings (alembic migrations, app config during tests)
TK_DB_USER=tropek
TK_DB_PASSWORD=tropek_test
TK_DB_HOST=localhost
TK_DB_PORT=5433
TK_DB_NAME=tropek_test

# Minimal values to satisfy settings validation — not used by tests
TK_REDIS_PASSWORD=
TK_SECRET_KEY=test-only-not-for-production
