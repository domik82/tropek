# Copy to .env and fill in values: cp .env.example .env
# Never commit .env to git

TK_DB_USER=tropek
TK_DB_PASSWORD=change-me
TK_REDIS_PASSWORD=change-me
# generate with: openssl rand -hex 32
TK_SECRET_KEY=change-me

# Optional — only needed if you run the Prometheus adapter against a real Prometheus
PROMETHEUS_URL=http://prometheus:9090
TK_ADAPTER_PROMETHEUS_USERNAME=
TK_ADAPTER_PROMETHEUS_PASSWORD=
