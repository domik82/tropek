# Copy to .env and fill in values: cp .env.example .env
# Never commit .env to git

QG_DB_USER=tropek
QG_DB_PASSWORD=change-me
QG_REDIS_PASSWORD=change-me
# generate with: openssl rand -hex 32
QG_SECRET_KEY=change-me

# Optional — only needed if you run the Prometheus adapter against a real Prometheus
PROMETHEUS_URL=http://prometheus:9090
QG_ADAPTER_PROMETHEUS_USERNAME=
QG_ADAPTER_PROMETHEUS_PASSWORD=
