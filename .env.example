# Copy to .env and fill in values before running
# Never commit .env to git

# Database credentials
QG_DB_USER=tropek
QG_DB_PASSWORD=changeme

# Redis password
QG_REDIS_PASSWORD=changeme

# Secret key for future API token signing
QG_SECRET_KEY=change-me-in-production-use-a-long-random-string

# Prometheus adapter credentials (optional - only if Prometheus requires auth)
# QG_ADAPTER_PROMETHEUS_USERNAME=
# QG_ADAPTER_PROMETHEUS_PASSWORD=

# Vault (optional - leave unset to use env vars instead)
# QG_VAULT_ADDR=https://vault.internal:8200
# QG_VAULT_TOKEN=s.xxxxx
# QG_VAULT_SECRET_PATH=secret/data/tropek

# Prometheus URL for the adapter (defaults to http://prometheus:9090)
# PROMETHEUS_URL=http://your-prometheus:9090
