# TROPEK deployment configuration
# Copy this file to .env and fill in the required values.

# --- Required: set these before starting ---
TK_DB_USER=tropek
TK_DB_PASSWORD=          # change this
TK_DB_NAME=tropek
TK_REDIS_PASSWORD=       # change this
TK_SECRET_KEY=           # generate with: openssl rand -hex 32

# --- Optional: pin to a specific release (default: latest) ---
# TROPEK_VERSION=v0.1.0-alpha

# --- Optional: use existing Postgres/Redis instead of bundled containers ---
# If set, these take precedence over the TK_DB_*/TK_REDIS_* component vars above.
# When using external infrastructure, remove the timescaledb and/or redis services
# from docker-compose.yml.
# TK_DATABASE_URL=postgresql+asyncpg://user:pass@your-host:5432/tropek
# TK_REDIS_URL=redis://:password@your-host:6379/0

# --- Prometheus adapter ---
PROMETHEUS_URL=http://your-prometheus:9090
# TK_ADAPTER_PROMETHEUS_USERNAME=
# TK_ADAPTER_PROMETHEUS_PASSWORD=
