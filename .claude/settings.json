{
  "permissions": {
    "allow": [
      "Bash(./scripts/api-test.sh --tail *)",
      "Bash(./scripts/ui-test.sh --tail *)",
      "Bash(./scripts/ui-lint.sh --tail *)",
      "Bash(just codegen)",
      "Bash(just export-schema)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/approve-safe-bash.sh",
            "timeout": 5,
            "statusMessage": "Checking command safety..."
          }
        ]
      }
    ]
  }
}
